{
  "_docs": "https://docs.openclaw.ai/gateway/configuration-reference",
  "_note": "Standalone OpenClaw config — no NemoClaw/NVIDIA required. Lives at ~/.openclaw/openclaw.json. Installed by scripts/07_openclaw.sh.",

  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": { "mode": "none" },
    "http": {
      "endpoints": {
        "responses": { "enabled": true }
      }
    }
  },

  "models": {
    "_note": "Brain: Qwen3.5-35B-A3B running via vLLM on port 8000.",
    "mode": "merge",
    "providers": {
      "local-vllm": {
        "baseUrl": "http://127.0.0.1:8000/v1",
        "apiKey": "unused",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen35-35b-a3b",
            "name": "Qwen3.5 35B A3B (local)",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 262144,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": { "primary": "local-vllm/qwen35-35b-a3b" },
      "workspace": "~/.openclaw/workspace"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Omar Agent",
        "identity": {
          "name": "Omar Agent",
          "emoji": "🤖",
          "theme": "private local AI on DGX Spark"
        }
      }
    ]
  },

  "ui": {
    "assistant": {
      "name": "Omar Agent",
      "avatar": "🤖"
    }
  },

  "mcpServers": {
    "_note": "All MCP servers use stdio transport. npm packages via npx, Python via uvx.",

    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/thatwonguy/projects"],
      "transport": "stdio"
    },

    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}" },
      "transport": "stdio"
    },

    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "/home/thatwonguy/projects"],
      "transport": "stdio"
    },

    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "transport": "stdio"
    },

    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres",
               "postgresql://postgres:localonly@localhost/agent_memory"],
      "transport": "stdio"
    },

    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "transport": "stdio"
    },

    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "transport": "stdio"
    }
  }
}
