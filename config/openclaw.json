{
  "_docs": "https://docs.nvidia.com/nemoclaw/latest/index.html",
  "_note": "OpenClaw config. NemoClaw wraps this. Keep close to defaults — NemoClaw onboard wizard writes ~/.nemoclaw/config.json separately. This file lives at ~/.openclaw/openclaw.json",

  "_model_note": "Brain is the sole model — vision, coding, agentic, reasoning at 50+ tok/s.",
  "model": "http://localhost:8000/v1/qwen35-35b-a3b",

  "agents": {
    "list": [
      {
        "id": "main",
        "name": "Omar Agent",
        "workspace": "~/.openclaw/workspace",
        "identity": {
          "name": "Omar Agent",
          "emoji": "🤖",
          "theme": "private local AI on DGX Spark"
        }
      }
    ]
  },

  "ui": {
    "assistant": {
      "name": "Omar Agent",
      "avatar": "🤖"
    }
  },

  "mcpServers": {
    "_note": "See config/mcp_servers.json for full catalog. Add/remove servers here. npm packages use npx. Python packages use uvx.",

    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem",
               "/home/thatwonguy/projects"]
    },

    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      }
    },

    "git": {
      "command": "uvx",
      "args": ["mcp-server-git",
               "--repository", "/home/thatwonguy/projects"]
    },

    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },

    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres",
               "postgresql://postgres:localonly@localhost/agent_memory"]
    },

    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"]
    },

    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    },

    "memory": {
      "_note": "Built-in MCP memory — augments our pgvector layer for in-session context",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    }
  }
}
