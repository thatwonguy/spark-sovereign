# =============================================================================
# spark-sovereign — environment variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_TOKEN=your_hf_token_here
HF_HUB_ENABLE_HF_TRANSFER=1

# ── SearXNG ───────────────────────────────────────────────────────────────────
# Leave blank to auto-generate on first run (set explicitly for stable restarts)
SEARXNG_SECRET_KEY=

# ── Telegram (optional) ───────────────────────────────────────────────────────
# Get bot token: message @BotFather on Telegram
# Get your user ID: message @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# ── Slack (optional) ──────────────────────────────────────────────────────────
# Create app at api.slack.com — needs bot token (xoxb-) and app token (xapp-)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_TEAM_ID=

# ── GitHub MCP ────────────────────────────────────────────────────────────────
# Personal access token with repo + workflow scopes
GITHUB_PAT=

# ── AWS MCP ───────────────────────────────────────────────────────────────────
AWS_PROFILE=default

# ── Stripe MCP ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── Notion MCP (optional) ─────────────────────────────────────────────────────
NOTION_API_TOKEN=

# ── Linear MCP (optional) ─────────────────────────────────────────────────────
LINEAR_API_KEY=

# ── Model paths (override defaults from config/models.yml) ───────────────────
MODELS_DIR=/opt/models
